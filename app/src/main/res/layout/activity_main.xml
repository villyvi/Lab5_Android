<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <TextView android:id="@+id/xValue" android:text="X: 0" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="28dp"/>
    <TextView android:id="@+id/yValue" android:text="Y: 0" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <TextView android:id="@+id/zValue" android:text="Z: 0" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/gForce"
        android:text="Current G: 0"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/maxG"
        android:text="Max G: 0.000"
        android:textSize="14sp"
        android:textColor="#B00020"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/resetBtn"
        android:text="Reset Max"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"/>

    <TextView
        android:text="Gforce"
        android:textSize="18sp"
        android:textColor="#FF6650a4"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"/>


    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/chart"
        android:layout_width="match_parent"
        android:layout_height="434dp"
        android:layout_marginTop="10dp" />

    <TextView
        android:text="Час"
        android:textSize="18sp"
        android:layout_gravity="right"
        android:layout_marginRight="10dp"
        android:textColor="#FF6650a4"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>